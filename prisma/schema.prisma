generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentMethod {
  CASH
  ONLINE
  PENDING
  SPLIT
}

enum PaymentStatus {
  PAID
  PARTIALLY_PAID
  PENDING
}

enum UserRole {
  ADMIN
  USER
  STAFF
}

enum ReturnStatus {
  RESTOCKED
  DAMAGED
}

enum OwnerTransactionType {
  DRAWING
  CAPITAL
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  password        String
  role            UserRole         @default(USER)
  active          Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  cashAdjustments CashAdjustment[] @relation("UserCashAdjustments")

  @@index([email])
  @@index([role])
}

model CashAdjustment {
  id         String        @id @default(cuid())
  amount     Float
  reason     String
  notes      String
  userId     String?
  user       User?         @relation("UserCashAdjustments", fields: [userId], references: [id])
  registerId String?
  register   CashRegister? @relation(fields: [registerId], references: [id])
  createdAt  DateTime      @default(now())
}

model CashRegister {
  id             String           @id @default(cuid())
  date           DateTime         @unique
  openingBalance Float            @default(0)
  actualClosing  Float?
  notes          String?
  closedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  adjustments    CashAdjustment[]

  @@index([date])
}

model ProductCategory {
  id              String                  @id @default(cuid())
  name            String                  @unique
  displayName     String
  description     String?
  sortOrder       Int                     @default(0)
  color           String                  @default("#8b5cf6")
  icon            String?
  isActive        Boolean                 @default(true)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  changeHistory   CategoryChangeHistory[]
  mixPreparations MixPreparation[]
  products        Product[]

  @@index([name])
  @@index([isActive])
  @@index([sortOrder])
}

model CategoryChangeHistory {
  id           String          @id @default(cuid())
  dateTime     DateTime        @default(now())
  categoryId   String
  fieldChanged String
  oldValue     String
  newValue     String
  changedBy    String          @default("System")
  createdAt    DateTime        @default(now())
  category     ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([dateTime])
}

model Product {
  id                        String                     @id @default(cuid())
  sku                       String                     @unique
  name                      String
  categoryId                String
  originalCost              Float
  sellingPrice              Float
  active                    Boolean                    @default(true)
  lowStockAlert             Int                        @default(10)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  imageUrl                  String?
  billItems                 BillItem[]
  damageLogs                DamageLog[]
  fruitbombIngredients      FruitbombIngredient[]
  inventoryLogs             InventoryLog[]
  mixDishIngredients        MixDishIngredient[]
  mixPreparationTargets     MixPreparation[]           @relation("MixPreparationTarget")
  mixPreparationIngredients MixPreparationIngredient[] @relation("MixPreparationIngredientProduct")
  category                  ProductCategory            @relation(fields: [categoryId], references: [id])
  returns                   ReturnLog[]
  skuChangeHistory          SKUChangeHistory[]
  currentStock              StockCurrent?
  stockTransferItems        StockTransferItem[]

  @@index([sku])
  @@index([categoryId])
  @@index([active])
}

model MixPreparation {
  id                     String                     @id @default(cuid())
  date                   DateTime                   @default(now())
  targetProductId        String
  sourceCategoryId       String
  preparedQuantity       Float
  remarks                String?
  createdAt              DateTime                   @default(now())
  producedUnits          Float                      @default(0)
  costUnits              Float                      @default(0)
  producedUnitsRemaining Float                      @default(0)
  costUnitsRemaining     Float                      @default(0)
  totalIngredientCost    Float                      @default(0)
  unitCostPerCostUnit    Float                      @default(0)
  sourceCategory         ProductCategory            @relation(fields: [sourceCategoryId], references: [id])
  targetProduct          Product                    @relation("MixPreparationTarget", fields: [targetProductId], references: [id])
  ingredients            MixPreparationIngredient[]

  @@index([date])
  @@index([targetProductId])
  @@index([sourceCategoryId])
  @@index([producedUnitsRemaining])
}

model MixPreparationIngredient {
  id            String         @id @default(cuid())
  preparationId String
  productId     String
  quantity      Float
  preparation   MixPreparation @relation(fields: [preparationId], references: [id], onDelete: Cascade)
  product       Product        @relation("MixPreparationIngredientProduct", fields: [productId], references: [id])

  @@index([preparationId])
  @@index([productId])
}

model StockCurrent {
  id              String   @id @default(cuid())
  productId       String   @unique
  currentStock    Float    @default(0)
  updatedAt       DateTime @updatedAt
  weightedAvgCost Float?
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([currentStock])
}

model InventoryLog {
  id              String        @id @default(cuid())
  date            DateTime      @default(now())
  productId       String
  unitsReceived   Float
  unitsOnline     Float         @default(0)
  unitsCash       Float         @default(0)
  unitsPending    Float         @default(0)
  paymentStatus   PaymentStatus @default(PENDING)
  costPrice       Float
  sellingPrice    Float
  profitMargin    Float
  remarks         String?
  originalCost    Float
  discountPercent Float         @default(0)
  avgCost         Float?
  supplierId      String?
  createdAt       DateTime      @default(now())
  product         Product       @relation(fields: [productId], references: [id])
  supplier        Supplier?     @relation(fields: [supplierId], references: [id])

  @@index([productId])
  @@index([date])
  @@index([paymentStatus])
}

model Bill {
  id                 String              @id @default(cuid())
  billNo             Int                 @unique @default(autoincrement())
  dateTime           DateTime            @default(now())
  customerName       String              @default("Walk-in-Cust")
  mobile             String?
  customerId         String?
  paymentMethod      PaymentMethod       @default(CASH)
  remarks            String?
  grandTotal         Float
  totalCost          Float
  totalProfit        Float
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  cashAmount         Float?
  onlineAmount       Float?
  refundTotal        Float               @default(0)
  customer           Customer?           @relation(fields: [customerId], references: [id])
  editLogs           BillEditLog[]
  lineItems          BillItem[]
  paymentCollections PaymentCollection[]
  returns            ReturnLog[]

  @@index([billNo])
  @@index([dateTime])
  @@index([customerId])
  @@index([paymentMethod])
  @@index([paymentMethod, dateTime])
}

model BillItem {
  id              String  @id @default(cuid())
  billId          String
  productId       String
  productName     String
  quantity        Float
  price           Float
  consumptionRate Float   @default(1)
  isMixDish       Boolean @default(false)
  unitCost        Float?
  lineCost        Float?
  bill            Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id])

  @@index([billId])
  @@index([productId])
}

model Customer {
  id                 String              @id @default(cuid())
  mobile             String              @unique
  name               String
  totalBills         Int                 @default(0)
  totalSpent         Float               @default(0)
  lastPurchase       DateTime            @default(now())
  firstPurchase      DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  customerNo         Int                 @unique @default(autoincrement())
  bills              Bill[]
  paymentCollections PaymentCollection[]

  @@index([mobile])
  @@index([totalSpent])
}

model DamageLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  productId String
  quantity  Float
  remarks   String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([date])
}

model StockTransferOutlet {
  id        String          @id @default(cuid())
  name      String
  type      String
  mobile    String
  email     String?
  address   String?
  notes     String?
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  transfers StockTransfer[]

  @@index([name])
  @@index([isActive])
}

model StockTransfer {
  id               String              @id @default(cuid())
  transferNo       Int                 @unique @default(autoincrement())
  outletId         String
  transferType     String
  transferDate     DateTime            @default(now())
  settlementType   String
  settlementStatus String              @default("PENDING")
  settledDate      DateTime?
  totalValue       Float?
  paidAmount       Float?              @default(0)
  paymentMethod    String?
  remarks          String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  outlet           StockTransferOutlet @relation(fields: [outletId], references: [id])
  items            StockTransferItem[]

  @@index([outletId])
  @@index([transferDate])
  @@index([transferType])
  @@index([settlementStatus])
}

model StockTransferItem {
  id         String        @id @default(cuid())
  transferId String
  productId  String
  quantity   Float
  price      Float?
  costPrice  Float
  remarks    String?
  product    Product       @relation(fields: [productId], references: [id])
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId])
  @@index([productId])
}

model MixDishPrep {
  id                String              @id @default(cuid())
  date              DateTime            @default(now())
  mixDishesPrepared Float
  createdAt         DateTime            @default(now())
  ingredients       MixDishIngredient[]

  @@index([date])
}

model MixDishIngredient {
  id           String      @id @default(cuid())
  prepId       String
  productId    String
  quantity     Float
  cubeFinished Boolean     @default(false)
  prep         MixDishPrep @relation(fields: [prepId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id])

  @@index([prepId])
  @@index([productId])
}

model FruitbombPrep {
  id                 String                @id @default(cuid())
  date               DateTime              @default(now())
  fruitbombsPrepared Float
  createdAt          DateTime              @default(now())
  ingredients        FruitbombIngredient[]

  @@index([date])
}

model FruitbombIngredient {
  id           String        @id @default(cuid())
  prepId       String
  productId    String
  quantity     Float
  cubeFinished Boolean       @default(false)
  prep         FruitbombPrep @relation(fields: [prepId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id])

  @@index([prepId])
  @@index([productId])
}

model SKUChangeHistory {
  id           String   @id @default(cuid())
  dateTime     DateTime @default(now())
  productId    String
  fieldChanged String
  oldValue     String
  newValue     String
  changedBy    String   @default("System")
  createdAt    DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([dateTime])
}

model PaymentPendingLog {
  id                 String         @id @default(cuid())
  date               DateTime       @default(now())
  sku                String
  productName        String
  unitsPending       Float
  costPrice          Float
  totalAmountPending Float
  paymentStatus      PaymentStatus  @default(PENDING)
  datePaid           DateTime?
  paymentMethod      PaymentMethod?
  unitsPaid          Float          @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([sku])
  @@index([paymentStatus])
}

model BillEditLog {
  id           String   @id @default(cuid())
  dateTime     DateTime @default(now())
  billId       String
  fieldChanged String
  oldValue     String
  newValue     String
  action       String
  createdAt    DateTime @default(now())
  bill         Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([dateTime])
}

model DailySalesSummary {
  id           String   @id @default(cuid())
  date         DateTime @unique
  totalSales   Float    @default(0)
  totalCost    Float    @default(0)
  totalProfit  Float    @default(0)
  totalBills   Int      @default(0)
  cashSales    Float    @default(0)
  onlineSales  Float    @default(0)
  avgBillValue Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
}

model Expense {
  id            String        @id @default(cuid())
  date          DateTime      @default(now())
  category      String
  description   String
  amount        Float
  paymentMethod PaymentMethod @default(CASH)
  remarks       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  paidFrom      String        @default("COUNTER")

  @@index([date])
  @@index([category])
  @@index([paidFrom])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  mobile         String?
  email          String?
  address        String?
  gstNumber      String?
  active         Boolean         @default(true)
  totalPurchase  Float           @default(0)
  totalPending   Float           @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventoryLogs  InventoryLog[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
  @@index([active])
}

model PurchaseOrder {
  id            String        @id @default(cuid())
  poNumber      String        @unique
  date          DateTime      @default(now())
  supplierId    String
  totalAmount   Float
  paidAmount    Float         @default(0)
  pendingAmount Float
  paymentStatus PaymentStatus @default(PENDING)
  deliveryDate  DateTime?
  status        String        @default("PENDING")
  remarks       String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  supplier      Supplier      @relation(fields: [supplierId], references: [id])

  @@index([poNumber])
  @@index([supplierId])
  @@index([date])
  @@index([status])
}

model PaymentCollection {
  id            String        @id @default(cuid())
  customerId    String
  billId        String?
  amount        Float
  date          DateTime      @default(now())
  paymentMethod PaymentMethod @default(CASH)
  remarks       String?
  createdAt     DateTime      @default(now())
  bill          Bill?         @relation(fields: [billId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([billId])
  @@index([date])
}

model OwnerTransaction {
  id            String               @id @default(cuid())
  type          OwnerTransactionType
  amount        Float
  date          DateTime             @default(now())
  description   String
  paymentMethod PaymentMethod        @default(CASH)
  remarks       String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([type])
  @@index([date])
}

model ReturnLog {
  id            String        @id @default(cuid())
  billId        String
  billItemId    String
  productId     String
  productName   String
  quantity      Float
  price         Float
  refundAmount  Float
  costAmount    Float
  reason        String
  status        ReturnStatus
  paymentMethod PaymentMethod @default(CASH)
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())
  bill          Bill          @relation(fields: [billId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@index([billId])
  @@index([productId])
  @@index([date])
}

model CashTransaction {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  fromLocation String
  toLocation   String
  amount       Float
  note         String
  category     String
  expenseId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
  @@index([fromLocation])
  @@index([toLocation])
  @@index([category])
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}