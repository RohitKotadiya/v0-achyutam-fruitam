# ============================================================
# STAGING environment variables
# Used by Vercel Preview deployments (staging branch)
# DB: neondb_staging on Neon — separate from dev and production
# ============================================================

DATABASE_URL="postgresql://neondb_owner:<PASSWORD>@ep-empty-frost-a4t0nt8i-pooler.us-east-1.aws.neon.tech/neondb_staging?sslmode=require&channel_binding=require"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="https://staging.your-domain.com"
POS_BASIC_AUTH_USER="qa-access"
POS_BASIC_AUTH_PASSWORD="replace-with-strong-password"
MAINTENANCE_API_KEY="replace-with-long-random-token"
PRISMA_ENABLE_LEGACY_MIDDLEWARE="false"

# Vercel Blob — required for product image uploads on serverless (Vercel)
# Generate token: Vercel Dashboard → Storage → Blob → Create Store → copy Read/Write Token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxx..."